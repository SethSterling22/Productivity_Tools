    {
      "parameters": {
        "jsCode": "const msg = $input.first().json;\nconst text = msg.message?.text || msg.message?.caption || '';\nreturn [{\n  json: {\n    raw_text: text,\n    chat_id: msg.message?.chat?.id,\n    username: msg.message?.from?.username || 'unknown',\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "extract-msg",
      "name": "Extract message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8080/tool/ollama_chat",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"qwen3:1.7b\",\n  \"temperature\": 0.1,\n  \"system\": \"You are an intent classifier. Respond ONLY with compact JSON, no markdown, no explanations. Categories: TASK = create/update/query a task, reminder, to-do or calendar event, including where to store it (Notion, Trello, etc.). Examples: 'add this to my calendar', 'guarda el task en Notion', 'recuerdame llamar al banco'. NOTE = create or query a note. Examples: 'quiero tomar nota de esto', 'apunta que...', 'save this as a note'. CONTENT = draft or publish a post or article. PROGRESS = log metrics or progress. TECHNICAL_QUERY = complex technical/engineering questions that need deep reasoning. SIMPLE_QUERY = short general questions. CHAT = greetings and casual conversation. Examples: 'hola', 'how are you'. Rules: use_claude=true ONLY for TECHNICAL_QUERY. For CHAT and SIMPLE_QUERY always use_claude=false. Output format: {\\\"intent\\\":\\\"CATEGORY\\\",\\\"confidence\\\":0.0-1.0,\\\"use_claude\\\":true|false}\",\n  \"prompt\": \"{{ $json.raw_text }}\"\n}"
      },
      "id": "hermes-classify",
      "name": "Hermes — Classify intent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1040,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const fast = $('Fast route').first().json;\nlet intent, confidence, use_claude, route;\n\nif (fast._decided) {\n  route = fast.route; intent = fast.intent; confidence = fast.confidence; use_claude = fast.use_claude;\n} else {\n  let parsed;\n  try {\n    let raw = $input.first().json.result || '{}';\n    raw = raw.replace(/<think>[\\s\\S]*?<\\/think>/g, '');   // qwen3 reasoning block\n    const cleaned = raw.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n    const match = cleaned.match(/\\{[\\s\\S]*\\}/);\n    parsed = JSON.parse(match ? match[0] : cleaned);\n  } catch (e) {\n    parsed = { intent: 'CHAT', confidence: 0.5, use_claude: false };\n  }\n  intent = parsed.intent || 'CHAT';\n  confidence = parsed.confidence ?? 0.5;\n  use_claude = !!parsed.use_claude;\n  // Casual conversation must always stay on local Qwen.\n  if (intent === 'CHAT' || intent === 'SIMPLE_QUERY') use_claude = false;\n  const KNOWN = ['TASK','NOTE','CONTENT','PROGRESS','CHAT','SIMPLE_QUERY'];\n  route = use_claude ? 'CLAUDE' : intent;\n  if (route !== 'CLAUDE' && !KNOWN.includes(route)) route = 'CHAT';\n}\n\nreturn [{ json: {\n  raw_text: fast.raw_text,\n  chat_id: fast.chat_id,\n  username: fast.username,\n  timestamp: fast.timestamp,\n  intent, confidence, use_claude, route\n} }];"
      },
      "id": "parse-intent",
      "name": "Parse intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1240,
        400
      ]
    },
