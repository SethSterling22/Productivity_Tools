      "id": "build-note",
      "name": "Build note",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1640,
        360
      ],
      "parameters": {
        "jsCode": "// Turn the incoming message into a note payload for Hermes note_save.\nconst d = $('Parse intent').first().json;\nconst text = (d.raw_text || '').trim();\nconst nl = text.indexOf('\\n');\nconst title = (nl === -1 ? text : text.slice(0, nl)).slice(0, 120) || 'Quick note';\nconst body = { title, content: text, folder: 'Inbox', tags: ['cerebro'], sync: true };\nreturn [{ json: { requestBody: JSON.stringify(body) } }];"
      }
    },
    {
      "id": "hermes-note-save",
      "name": "Hermes → Save note",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1840,
        360
      ],
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8080/tool/note_save",
        "sendHeaders": true,
