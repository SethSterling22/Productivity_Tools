    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\nreturn [{ json: { response_text: r.result || 'No response.', source: 'Hermes/Ollama' } }];"
      },
      "id": "parse-ollama",
      "name": "Parse Ollama",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        780
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Parse intent').first().json;\nreturn [{ json: { response_text: `✍️ [Content Agent — Phase 4]\\nDetected: \"${d.raw_text}\"`, source: 'Content-Agent' } }];"
      },
      "id": "agent-content",
      "name": "Content Agent [TODO Phase 4]",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1700,
        480
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Parse intent').first().json;\nreturn [{ json: { response_text: `📊 [Progress Agent — Phase 5]\\nDetected: \"${d.raw_text}\"`, source: 'Progress-Agent' } }];"
      },
      "id": "agent-progress",
      "name": "Progress Agent [TODO Phase 5]",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1700,
        620
      ]
    },
    {
      "parameters": {
        "jsCode": "const all = $input.all();\nconst r = all.find(i => i.json.response_text) || all[0];\nconst d = $('Parse intent').first().json;\nconst src = r.json.source || 'System';\nconst icon = src === 'Claude' ? '🤖' : src.includes('Ollama') ? '⚡' : '🔧';\nreturn [{\n  json: {\n    chat_id: d.chat_id,\n    response_text: r.json.response_text,\n    footer: `\\n\\n${icon} ${src} · ${d.intent} (${Math.round((d.confidence||0)*100)}%)`\n  }\n}];"
      },
      "id": "merge",
      "name": "Merge response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        400
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "={{ $json.response_text + $json.footer }}",
        "additionalFields": {}
      },
      "id": "telegram-send",
      "name": "Telegram — Send",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        2380,
        400
      ],
      "credentials": {
        "telegramApi": {
          "id": "YOUR_TELEGRAM_CRED",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nlet text = (d.raw_text || '').trim();\nconst lower = text.toLowerCase();\n\n// Slash commands go straight to an agent (skip the qwen classifier).\nconst SLASH = { '/claude':'CLAUDE', '/task':'TASK', '/note':'NOTE', '/content':'CONTENT', '/progress':'PROGRESS', '/qwen':'CHAT', '/chat':'CHAT' };\nlet decided = false, route = null;\nconst m = lower.match(/^(\\/[a-z]+)\\b/);\nif (m && SLASH[m[1]]) {\n  route = SLASH[m[1]];\n  decided = true;\n  text = text.slice(m[1].length).trim();   // strip the command token\n}\n\n// Very large prompts go straight to Claude (skip classification).\nconst MAX_LOCAL_CHARS = 1500;\nif (!decided && text.length > MAX_LOCAL_CHARS) { route = 'CLAUDE'; decided = true; }\n\nconst intent = route === 'CLAUDE' ? 'TECHNICAL_QUERY' : (route || 'CHAT');\nreturn [{\n  json: {\n    raw_text: text,\n    chat_id: d.chat_id,\n    username: d.username,\n    timestamp: d.timestamp,\n    _decided: decided,\n    route: decided ? route : null,\n    intent: decided ? intent : null,\n    confidence: decided ? 1 : null,\n    use_claude: decided ? (route === 'CLAUDE') : false\n  }\n}];"
      },
      "id": "fast-route",
      "name": "Fast route",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
