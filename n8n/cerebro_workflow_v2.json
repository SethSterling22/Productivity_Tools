    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8080/tool/ollama_chat",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"qwen3.5:4b\",\n  \"temperature\": 0.7,\n  \"system\": \"You are Sebastian's personal assistant. Detected intent: {{ $('Parse intent').first().json.intent }}. Be direct and concise. Respond in the user's language.\",\n  \"prompt\": \"={{ $('Parse intent').first().json.raw_text }}\"\n}"
      },
