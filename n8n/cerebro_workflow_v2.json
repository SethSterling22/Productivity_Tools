    {
      "id": "parse-note",
      "name": "Parse note",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2040,
        360
      ],
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst text = r.ok ? `📝 ${r.result}` : `⚠️ Note not saved: ${r.error || 'unknown error'}`;\nreturn [{ json: { response_text: text, source: 'Brain' } }];"
      }
    },
    {
      "id": "build-task",
      "name": "Build task",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1640,
        160
      ],
      "parameters": {
        "jsCode": "// Build a Linear GraphQL mutation from the incoming message.\n// First line -> issue title, the rest -> description.\nconst d = $('Parse intent').first().json;\nconst text = (d.raw_text || '').trim();\nconst nl = text.indexOf('\\n');\nconst title = (nl === -1 ? text : text.slice(0, nl)).slice(0, 200) || 'Untitled task';\nconst description = nl === -1 ? '' : text.slice(nl + 1).trim();\n// TODO: set your Linear team id (see setup instructions).\nconst teamId = 'REPLACE_WITH_LINEAR_TEAM_ID';\nconst body = {\n  query: 'mutation CreateIssue($teamId: String!, $title: String!, $description: String) { issueCreate(input: { teamId: $teamId, title: $title, description: $description }) { success issue { identifier title url } } }',\n  variables: { teamId, title, description },\n};\nreturn [{ json: { requestBody: JSON.stringify(body) } }];"
      }
    },
    {
      "id": "linear-create",
      "name": "Linear — Create issue",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1840,
        160
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.linear.app/graphql",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.requestBody }}"
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "",
          "name": "Linear API Key"
        }
      }
    },
    {
      "id": "parse-task",
      "name": "Parse task",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2040,
        160
      ],
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst res = r && r.data && r.data.issueCreate;\nconst issue = res && res.issue;\nconst text = (res && res.success && issue)\n  ? `✅ Task created in Linear: ${issue.identifier} — ${issue.title}\\n${issue.url}`\n  : `⚠️ Could not create the Linear task.\\n${JSON.stringify((r && r.errors) || r).slice(0, 400)}`;\nreturn [{ json: { response_text: text, source: 'Linear' } }];"
      }
    }
