# ── n8n + Hermes — environment variable template ─────────────────────────────
# Copy this file to .env and fill in the values. Do NOT commit .env (it is in .gitignore).
#   cp .env.example .env

# ── Tailscale ────────────────────────────────────────────────────────────────
# Reusable, non-ephemeral auth key. Generate it at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Must match the already-initialized postgres_data volume. If you change it on an
# existing DB, authentication will fail until the volume is recreated.
POSTGRES_PASSWORD=change-this-password

# ── n8n ──────────────────────────────────────────────────────────────────────
# Key used to encrypt credentials stored inside n8n.
# WARNING: do NOT rotate it on an existing install — you would lose access to already-saved credentials.
# Generate a new one with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# ── Claude API (Anthropic) ───────────────────────────────────────────────────
# Leave EMPTY if you do not have a key yet: Hermes will automatically fall back
# to the local Qwen model (HERMES_CLAUDE_FALLBACK_MODEL) for claude_chat calls.
ANTHROPIC_API_KEY=

# ── Hermes capability toggles ────────────────────────────────────────────────
# All OFF by default (safest). Set to "true" to grant a capability.
# WARNING: these widen what the agent can do to your machines. Enable only what
# you need, when you need it.
#
# SSH into cluster nodes (ssh/scp/sftp/rsync). Also mount an SSH key in the
# compose file and authorize it on the target nodes.
HERMES_ALLOW_SSH=false
# Run ANY shell command through bash -lc (pipes, redirects, rm, apt, etc.).
# This is effectively full control of the Hermes container — use with care.
HERMES_ALLOW_UNRESTRICTED_SHELL=false
# Add specific extra binaries without going fully unrestricted, e.g. "rm,mv,cp,tar".
HERMES_SHELL_EXTRA=
# Let fs_list/fs_read/fs_write/fs_delete reach outside /workspace.
HERMES_FS_UNRESTRICTED=false
# Allow fs_write to target an arbitrary path (implied by HERMES_FS_UNRESTRICTED).
HERMES_FS_ALLOW_WRITE_ANYWHERE=false
# Enable the fs_delete tool.
HERMES_FS_ALLOW_DELETE=false
# Local model used when Claude is unavailable.
HERMES_CLAUDE_FALLBACK_MODEL=qwen3.5:4b

